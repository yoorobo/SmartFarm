/**
 * wifi_config.h 템플릿
 * ====================
 * 이 파일은 예시입니다. 실제 wifi_config.h는 .env에서 생성됩니다.
 *
 * 사용법:
 *   1. cp .env.example .env
 *   2. .env 편집 (WIFI_SSID, WIFI_PASSWORD, SERVER_IP)
 *   3. python3 scripts/update_wifi_config.py
 *
 * 생성된 wifi_config.h는 config/, esp32-cam/, robot-firmware/ 에 생성됩니다.
 */

#ifndef WIFI_CONFIG_H
#define WIFI_CONFIG_H

#define WIFI_SSID     "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"
#define SERVER_IP     "192.168.0.xxx"

#define SERVER_TCP_PORT 8080
#define SERVER_UDP_PORT 7070

#endif
